# LLM Provider: "openai" or "ollama"
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
OPENAI_API_KEY=<your-api-key>

# Ollama (if using local LLM)
OLLAMA_URL=http://localhost:11434

# Browser
HEADLESS=true

# Notifications (optional)
NOTIFICATIONS_ENABLED=false
SLACK_WEBHOOK_URL=
FIREBASE_URL=

# Logging
LOG_LEVEL=INFO
