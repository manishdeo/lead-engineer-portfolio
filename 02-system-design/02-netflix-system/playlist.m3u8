#EXTM3U
#EXT-X-VERSION:3

# --- Master Playlist for Adaptive Bitrate Streaming (HLS) ---
# Each stream below represents a different quality level.
# The client player chooses the best stream based on current network conditions.

# Stream 1: 480p (Low bandwidth)
#EXT-X-STREAM-INF:PROGRAM-ID=1,BANDWIDTH=800000,RESOLUTION=854x480,CODECS="avc1.4d401f,mp4a.40.2"
480p/stream.m3u8

# Stream 2: 720p (Medium bandwidth)
#EXT-X-STREAM-INF:PROGRAM-ID=1,BANDWIDTH=2500000,RESOLUTION=1280x720,CODECS="avc1.64001f,mp4a.40.2"
720p/stream.m3u8

# Stream 3: 1080p (High bandwidth)
#EXT-X-STREAM-INF:PROGRAM-ID=1,BANDWIDTH=5000000,RESOLUTION=1920x1080,CODECS="avc1.640028,mp4a.40.2"
1080p/stream.m3u8

# Stream 4: 4K with HEVC/H.265 codec (Very high bandwidth)
#EXT-X-STREAM-INF:PROGRAM-ID=1,BANDWIDTH=20000000,RESOLUTION=3840x2160,CODECS="hvc1.1.6.L153.B0,mp4a.40.2"
4k/stream.m3u8

